# --- Core paths ---
# Adjust these paths according to your local Windows setup.
BASE_PATH=C:\\Users\\<usuario>\\OneDrive - Gaseosas Postobon S.A\\Escritorio\\Automatizaciones_postobon
FACTURAS_ROOT=${BASE_PATH}\\Facturas
FACTURAS_PATH=${FACTURAS_ROOT}\\entrada
FACTURAS_PROCESADAS=${FACTURAS_ROOT}\\salida
FACTURAS_RECHAZADOS=${FACTURAS_ROOT}\\rechazados
FACTURAS_ERRORES=${FACTURAS_ROOT}\\errores
FACTURAS_CODIGO_PATH=${FACTURAS_ROOT}\\cod_facturas
EXCEL_SALIDA=${FACTURAS_ROOT}\\procesadas.xlsx
WEB_ASSETS_PATH=${BASE_PATH}\\Web

# --- Upload and API security ---
MAX_CONTENT_LENGTH_MB=100
ALLOWED_UPLOAD_EXTENSIONS=.pdf
ALLOWED_EXCEL_EXTENSIONS=.xlsx,.xls,.xlsm
CORS_ORIGINS=http://localhost:5000,http://127.0.0.1:5000

# --- Flask runtime ---
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=false

# --- Excel automation ---
DESHABILITAR_ACTUALIZACION_EXCEL=true
